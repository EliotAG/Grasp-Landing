# Port Next.js binds to. Grasp will call this from server actions, so it
# must be reachable from the Grasp dev process (typically localhost).
PORT="4000"

# Shared secret used in BOTH directions:
# - Grasp -> Simulator:   sets `Authorization: Bearer ${SIMULATOR_SHARED_SECRET}`
# - Simulator -> Grasp:   sets `Authorization: Bearer ${SIMULATOR_SHARED_SECRET}`
# Use any string >= 32 chars. Generate with: openssl rand -base64 32
SIMULATOR_SHARED_SECRET=""

# Secret used to validate launch tokens minted by the Grasp admin
# dashboard and to sign the simulator's httpOnly admin cookie. If
# omitted, SIMULATOR_SHARED_SECRET is used. In hosted demo/staging,
# set this to the same value as SIMULATOR_ADMIN_SECRET in the app.
SIMULATOR_ADMIN_SECRET=""

# Where to POST user replies back to (Grasp's webhook). Optional —
# without it the simulator just stores messages locally; the agent
# never replies. Set to e.g. http://localhost:3001/api/sim/incoming
GRASP_WEBHOOK_URL=""

# Where the access-denied page sends internal users to launch the
# simulator through Grasp's authenticated admin dashboard.
NEXT_PUBLIC_GRASP_APP_URL="http://localhost:3000"
