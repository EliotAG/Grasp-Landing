# --- Database (Neon Postgres recommended) ---
# Get one free at https://neon.tech, or `vercel link` then `vercel env pull`.
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# --- Auth.js core ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Set in production to your canonical URL, e.g. https://app.withgrasp.com
# Leave blank in local dev (Auth.js uses request URL).
AUTH_URL=""

# --- Google OAuth (optional but recommended for fastest sign-in) ---
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Closed-pilot gating ---
# Anyone can sign up and create a workspace. Activation, amendments,
# and Teams/Slack integrations are gated on Organization.approved_at.
# Approve a pilot workspace by hand:
#
#   pnpm tsx scripts/approve-org.ts <slug>
#
# Or set the column directly in psql / Prisma Studio.

# Used by /onboarding and other places that link back to the marketing
# site. Defaults to the prod marketing domain when unset.
NEXT_PUBLIC_MARKETING_URL="https://www.withgrasp.com"

# --- Email sign-in codes ---
# Production path: create a Resend API key and verify the sending domain in
# Resend. Set EMAIL_FROM to an address on that verified domain.
RESEND_API_KEY=""
EMAIL_FROM="Grasp <noreply@withgrasp.com>"

# Optional SMTP fallback. If RESEND_API_KEY and SMTP are both unset in dev,
# sign-in codes are printed to your terminal so you can sign in locally.
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""

# --- Planning wizard (AI assist) ---
# Anthropic Claude powers stakeholder/behavior/announcement drafting and the
# three scoring rubrics on the announcement step. The wizard degrades
# gracefully if this is unset (manual entry only — AI buttons disabled).
ANTHROPIC_API_KEY=""
# Optional model override; default below matches the model named in the spec.
ANTHROPIC_MODEL="claude-sonnet-4-5"

# --- Microsoft Teams bot (proactive messaging) ---
# From the Azure / Entra app registration that backs the bot. The bot is
# installed tenant-wide via Teams Admin Center per pilot company.
#
# Use the legacy "MicrosoftApp*" names — the @microsoft/agents-hosting
# SDK reads these via loadPrevAuthConfigFromEnv when no `clientId` is set.
# See: https://github.com/microsoft/Agents-for-js
#
# Local dev: run `ngrok http 3000` and set the bot's messaging endpoint
# to https://<ngrok-id>.ngrok-free.app/api/teams/messages in the Azure
# Bot Service blade. Without it Teams cannot deliver activities to your
# laptop and conversation references will never be captured.
# For the YC demo tenant, SingleTenant is simplest. Use MultiTenant later
# if one app registration will serve multiple customer tenants.
MicrosoftAppType="SingleTenant"
MicrosoftAppId=""
MicrosoftAppPassword=""
MicrosoftAppTenantId=""

# --- Microsoft Teams Graph bootstrap ---
# Optional but recommended for production Teams rollout. Grant the same Entra
# app the Microsoft Graph application permission
# TeamsAppInstallation.ReadWriteForUser.All with admin consent, publish the
# Teams app to the org app catalog, then set one of these identifiers.
#
# TEAMS_APP_MANIFEST_ID is the `id` in teams-app-manifest.template.json.
# TEAMS_APP_CATALOG_ID is the Graph appCatalogs/teamsApps id returned after the
# app is uploaded to the org catalog. If omitted, Grasp looks it up by manifest
# id before installing the app for employees.
TEAMS_APP_MANIFEST_ID=""
TEAMS_APP_CATALOG_ID=""

# --- Planning wizard (training-doc upload) ---
# Vercel Blob token for storing leader-uploaded training docs (PDF/DOCX/MD)
# scoped to a single change plan. Get one at vercel.com/dashboard/stores.
# Without it, the materials step is read-only with an inline notice.
BLOB_READ_WRITE_TOKEN=""

# --- Grasp Simulator (testing) ---
# A standalone Next.js app in `simulator/` that pretends to be Microsoft
# Teams. When configured, Grasp also delivers kickoff DMs (and any
# future agent messages) to the simulator alongside the real Teams send,
# and accepts replies from it at /api/sim/incoming. Without these set,
# the integration is a no-op — Grasp behaves exactly like before.
#
#   cd simulator && pnpm install && pnpm dev   # http://localhost:4000
#
# SIMULATOR_URL is server-side; NEXT_PUBLIC_SIMULATOR_URL is the link
# the internal admin launcher opens (usually the same value).
SIMULATOR_URL="http://localhost:4000"
NEXT_PUBLIC_SIMULATOR_URL="http://localhost:4000"
# Shared secret for both directions (Grasp -> Simulator and back).
# Must match SIMULATOR_SHARED_SECRET in simulator/.env.local.
# Generate: openssl rand -base64 32
SIMULATOR_SHARED_SECRET=""
# Secret used to sign short-lived admin launch tokens from Grasp into
# the simulator. If omitted, SIMULATOR_SHARED_SECRET is used. In hosted
# demo/staging, set this to the same value in both app and simulator.
SIMULATOR_ADMIN_SECRET=""

# --- Scheduled check-in cron ---
# Bearer token the /api/cron/check-ins endpoint requires. Vercel Cron
# sends this automatically when the env var is set on the project.
# In local dev, hit the route manually:
#   curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/cron/check-ins
# Generate: openssl rand -base64 32
CRON_SECRET=""

# --- Voice kickoff (Microsoft Graph + Recall.ai + OpenAI Realtime) ---
# Optional. Powers the per-plan "voice kickoff calls" surface: when a
# leader enables it on the wizard's cadence step and activates the
# plan, Grasp uses Microsoft Graph to (1) create a unique Teams
# meeting per enrollee on the leader's Outlook calendar and (2) send
# a real Outlook calendar invite to each enrollee with the join URL
# embedded. Then at the scheduled time, Grasp deploys an AI bot into
# each meeting via Recall.ai with OpenAI Realtime as the voice loop.
# The text agent (kickoff DMs, check-ins, amendments) stays on
# Anthropic — only the voice surface uses OpenAI.
#
# Microsoft side prerequisites (one-time, in your test tenant):
#   1. In the Grasp bot's Azure AD app registration → API permissions,
#      add Application permissions:
#        - OnlineMeetings.ReadWrite.All
#        - Calendars.ReadWrite
#      then click "Grant admin consent for <tenant>".
#   2. In Teams PowerShell, grant the bot's app id permission to
#      create meetings on behalf of users (without this you'll get
#      403s on the Graph onlineMeetings POST):
#        Install-Module MicrosoftTeams -Scope CurrentUser
#        Connect-MicrosoftTeams
#        New-CsApplicationAccessPolicy -Identity "GraspMeetings" \
#          -AppIds "<MicrosoftAppId>" -Description "Grasp - on-behalf-of meeting creation"
#        Grant-CsApplicationAccessPolicy -PolicyName "GraspMeetings" -Global
#      Wait ~30min for the policy to propagate before the first
#      activation. Use the wizard's "Test connection" button to
#      verify the policy is live.
#   3. The leader who activates the plan must have a Microsoft 365
#      mailbox in the tenant — meetings are created on their calendar
#      and they appear as the organizer to enrollees.
RECALL_API_KEY=""
# Recall.ai regional API host. us-east-1 is the default; pick the
# region closest to your tenant for lowest call latency.
RECALL_API_HOST="us-east-1.recall.ai"
# OpenAI key used for the Realtime voice loop. Not used by the text
# agent. Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=""
# gpt-realtime-2 is the GA model (released May 7, 2026) with GPT-5-class
# reasoning and a 128K context window. Override here if you want to fall
# back to gpt-4o-realtime-preview or pin to a different snapshot.
OPENAI_REALTIME_MODEL="gpt-realtime-2"
# Public URL Recall.ai posts call-status webhooks to. In dev this is
# your ngrok URL plus the path; in prod your AUTH_URL plus the path.
# Leave blank to default to ${AUTH_URL}/api/calls/recall-webhook.
RECALL_WEBHOOK_URL=""
